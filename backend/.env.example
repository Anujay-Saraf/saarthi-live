LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx
SARVAM_LLM_MODEL=sarvam-m
SARVAM_TTS_TARGET_LANGUAGE=hi-IN
SARVAM_TTS_SPEAKER=anand
ENABLE_IDLE_PROMPTS=false
SILENCE_CHECK_SECONDS=8
MAX_IDLE_PROMPTS=2
MAX_VOICE_CHUNK_SECONDS=25
MAX_CHAT_CONTEXT_CHARS=6000
TOKEN_SERVER_PORT=8787

# Security/governance defaults are dev-friendly. Tighten these for shared demos or production.
SAARTHI_CORS_ORIGINS=*
SAARTHI_API_TOKEN=
SAARTHI_REQUIRE_CONSENT=false
SAARTHI_RATE_LIMIT_PER_MINUTE=90
SAARTHI_MAX_UPLOAD_MB=8
SAARTHI_AUDIT_ENABLED=true
SAARTHI_AUDIT_LOG_PATH=appendix/audit-events.jsonl
SAARTHI_RETENTION_POLICY=No conversation DB; metadata audit only.
