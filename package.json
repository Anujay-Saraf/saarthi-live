{
  "name": "saarthi-live",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --host lan --port 8082",
    "backend:token": "cd backend && .venv\\Scripts\\python.exe -m uvicorn token_server:app --host 0.0.0.0 --port 8787",
    "backend:agent": "cd backend && .venv\\Scripts\\python.exe agent.py dev",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
